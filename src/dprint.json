{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"indentWidth": 4,
	"lineWidth": 180,
	"newLineKind": "lf",
	"useTabs": true,
	"excludes": [
		"dist/**",
		"**/node_modules/**",
		"**/*-lock.yaml",
		"**/*-lock.json"
	],
	"dockerfile": {
		"lineWidth": 180,
		"newLineKind": "lf"
	},
	"json": {
		"indentWidth": 4,
		"lineWidth": 180,
		"newLineKind": "lf",
		"useTabs": true,

		"commentLine.forceSpaceAfterSlashes": true,
		"ignoreNodeCommentText": "dprint-ignore-line",
		"jsonTrailingCommaFiles": [
			"tsconfig.json",
			".vscode/settings.json"
		],
		"preferSingleLine": false,
		"trailingCommas": "never"
	},
	"malva": {
		"indentWidth": 4,
		"useTabs": true,
		"printWidth": 180,
		"lineBreak": "lf",

		"alignComments": true,
		"attrValueQuotes": "always",
		"blockSelectorLinebreak": "consistent",
		"declarationOrder": null,
		"declarationOrderGroupBy": "nonDeclarationAndEmptyLine",
		"fontFamilyNames": "consistent",
		"formatComments": true,
		"hexCase": "lower",
		"hexColorLength": "long",
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"keyframeSelectorNotation": "percentage",
		"linebreakInPseudoParens": false,
		"nthPlusSpacing": true,
		"omitNumberLeadingZero": false,
		"operatorLinebreak": "after",
		"preferSingleLine": false,
		"quotes": "preferSingle",
		"selectorOverrideCommentDirective": "dprint-ignore-selector",
		"singleLineBlockThreshold": 1,
		"singleLineTopLevelDeclarations": false,
		"trailingComma": false
	},
	"markdown": {
		"lineWidth": 180,
		"newLineKind": "lf",

		"emphasisKind": "underscores",
		"headingKind": "atx",
		"ignoreDirective": "dprint-ignore-line",
		"ignoreEndDirective": "dprint-ignore-end",
		"ignoreFileDirective": "dprint-ignore",
		"ignoreStartDirective": "dprint-ignore-start",
		"listIndentKind": "commonMark",
		"strongKind": "asterisks",
		"tags": null,
		"textWrap": "maintain",
		"unorderedListKind": "dashes"
	},
	"markup": {
		"indentWidth": 4,
		"useTabs": true,
		"printWidth": 180,
		"lineBreak": "lf",

		"closingBracketSameLine": false,
		"closingTagLineBreakForEmpty": "fit",
		"doctypeKeywordCase": "lower",
		"formatComments": true,
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"maxAttrsPerLine": null,
		"preferAttrsSingleLine": false,
		"quotes": "double",
		"scriptFormatter": "dprint",
		"scriptIndent": true,
		"singleAttrSameLine": true,
		"styleIndent": true,
		"whitespaceSensitivity": "css",

		"angularNextControlFlowSameLine": true,

		"astro.scriptIndent": true,
		"astro.styleIndent": true,
		"astroAttrShorthand": true,

		"component.selfClosing": true,
		"component.whitespaceSensitivity": "css",

		"html.normal.selfClosing": false,
		"html.scriptIndent": true,
		"html.styleIndent": true,
		"html.void.selfClosing": true,
		"mathml.selfClosing": false,
		"svg.selfClosing": true,

		"strictSvelteAttribute": true,
		"svelte.scriptIndent": true,
		"svelte.styleIndent": true,
		"svelteAttrShorthand": true,
		"svelteDirectiveShorthand": true,

		"component.vSlotStyle": "short",
		"default.vSlotStyle": "short",
		"named.vSlotStyle": "short",
		"vBindSameNameShortHand": false,
		"vBindStyle": "short",
		"vForDelimiterStyle": "of",
		"vOnStyle": "short",
		"vSlotStyle": "short",
		"vue.scriptIndent": true,
		"vue.styleIndent": true,
		"vueComponentCase": "pascalCase"
	},
	"toml": {
		"indentWidth": 4,
		"lineWidth": 180,
		"newLineKind": "lf",
		"useTabs": true,

		"comment.forceLeadingSpace": true,
		"cargo.applyConventions": true
	},
	"typescript": {
		"indentWidth": 4,
		"lineWidth": 180,
		"newLineKind": "lf",
		"useTabs": true,

		"arguments.preferHanging": "never",
		"arguments.preferSingleLine": false,
		"arguments.spaceAround": false,
		"arguments.trailingCommas": "never",
		"arrayExpression.preferHanging": "never",
		"arrayExpression.preferSingleLine": false,
		"arrayExpression.spaceAround": false,
		"arrayExpression.trailingCommas": "never",
		"arrayPattern.preferHanging": false,
		"arrayPattern.preferSingleLine": false,
		"arrayPattern.spaceAround": false,
		"arrayPattern.trailingCommas": "never",
		"arrowFunction.bracePosition": "sameLine",
		"arrowFunction.useParentheses": "force",
		"binaryExpression.linePerExpression": false,
		"binaryExpression.operatorPosition": "maintain",
		"binaryExpression.preferSingleLine": false,
		"binaryExpression.spaceSurroundingBitwiseAndArithmeticOperator": true,
		"bracePosition": "sameLine",
		"catchClause.spaceAround": false,
		"classDeclaration.bracePosition": "sameLine",
		"classExpression.bracePosition": "sameLine",
		"commentLine.forceSpaceAfterSlashes": true,
		"computed.preferSingleLine": false,
		"conditionalExpression.operatorPosition": "maintain",
		"conditionalExpression.preferSingleLine": false,
		"conditionalType.operatorPosition": "maintain",
		"conditionalType.preferSingleLine": false,
		"constructor.bracePosition": "sameLine",
		"constructor.spaceBeforeParentheses": false,
		"constructorType.spaceAfterNewKeyword": true,
		"constructSignature.spaceAfterNewKeyword": true,
		"decorators.preferSingleLine": false,
		"doWhileStatement.bracePosition": "sameLine",
		"doWhileStatement.nextControlFlowPosition": "sameLine",
		"doWhileStatement.preferHanging": false,
		"doWhileStatement.spaceAfterWhileKeyword": true,
		"doWhileStatement.spaceAround": false,
		"enumDeclaration.bracePosition": "sameLine",
		"enumDeclaration.memberSpacing": "newLine",
		"enumDeclaration.trailingCommas": "never",
		"exportDeclaration.forceMultiLine": "never",
		"exportDeclaration.forceSingleLine": false,
		"exportDeclaration.preferHanging": false,
		"exportDeclaration.preferSingleLine": false,
		"exportDeclaration.sortNamedExports": "caseInsensitive",
		"exportDeclaration.sortTypeOnlyExports": "first",
		"exportDeclaration.spaceSurroundingNamedExports": true,
		"exportDeclaration.trailingCommas": "never",
		"extendsClause.preferHanging": false,
		"forInStatement.bracePosition": "sameLine",
		"forInStatement.preferHanging": false,
		"forInStatement.singleBodyPosition": "maintain",
		"forInStatement.spaceAfterForKeyword": true,
		"forInStatement.spaceAround": false,
		"forInStatement.useBraces": "always",
		"forOfStatement.bracePosition": "sameLine",
		"forOfStatement.preferHanging": false,
		"forOfStatement.singleBodyPosition": "maintain",
		"forOfStatement.spaceAfterForKeyword": true,
		"forOfStatement.spaceAround": false,
		"forOfStatement.useBraces": "always",
		"forStatement.bracePosition": "sameLine",
		"forStatement.preferHanging": false,
		"forStatement.preferSingleLine": false,
		"forStatement.singleBodyPosition": "maintain",
		"forStatement.spaceAfterForKeyword": true,
		"forStatement.spaceAfterSemiColons": true,
		"forStatement.spaceAround": false,
		"forStatement.useBraces": "always",
		"functionDeclaration.bracePosition": "sameLine",
		"functionDeclaration.spaceBeforeParentheses": false,
		"functionExpression.bracePosition": "sameLine",
		"functionExpression.flatIife": false,
		"functionExpression.spaceAfterFunctionKeyword": false,
		"functionExpression.spaceBeforeParentheses": false,
		"getAccessor.bracePosition": "sameLine",
		"getAccessor.spaceBeforeParentheses": false,
		"ifStatement.bracePosition": "sameLine",
		"ifStatement.nextControlFlowPosition": "sameLine",
		"ifStatement.preferHanging": false,
		"ifStatement.singleBodyPosition": "maintain",
		"ifStatement.spaceAfterIfKeyword": true,
		"ifStatement.spaceAround": false,
		"ifStatement.useBraces": "always",
		"ignoreFileCommentText": "dprint-ignore",
		"ignoreNodeCommentText": "dprint-ignore-line",
		"implementsClause.preferHanging": false,
		"importDeclaration.forceMultiLine": "never",
		"importDeclaration.forceSingleLine": false,
		"importDeclaration.preferHanging": false,
		"importDeclaration.preferSingleLine": false,
		"importDeclaration.sortNamedImports": "caseInsensitive",
		"importDeclaration.sortTypeOnlyImports": "first",
		"importDeclaration.spaceSurroundingNamedImports": true,
		"importDeclaration.trailingCommas": "never",
		"interfaceDeclaration.bracePosition": "sameLine",
		"jsx.bracketPosition": "nextLine",
		"jsx.forceNewLinesSurroundingContent": false,
		"jsx.multiLineParens": "always",
		"jsx.quoteStyle": "preferDouble",
		"jsxAttributes.preferHanging": false,
		"jsxAttributes.preferSingleLine": false,
		"jsxElement.preferSingleLine": false,
		"jsxExpressionContainer.spaceSurroundingExpression": false,
		"jsxOpeningElement.bracketPosition": "nextLine",
		"jsxSelfClosingElement.bracketPosition": "nextLine",
		"jsxSelfClosingElement.spaceBeforeSlash": true,
		"mappedType.preferSingleLine": false,
		"memberExpression.linePerExpression": false,
		"memberExpression.preferSingleLine": false,
		"method.bracePosition": "sameLine",
		"method.spaceBeforeParentheses": false,
		"module.sortExportDeclarations": "caseInsensitive",
		"module.sortImportDeclarations": "caseInsensitive",
		"moduleDeclaration.bracePosition": "sameLine",
		"nextControlFlowPosition": "sameLine",
		"objectExpression.preferHanging": false,
		"objectExpression.preferSingleLine": false,
		"objectExpression.spaceSurroundingProperties": true,
		"objectExpression.trailingCommas": "never",
		"objectPattern.preferHanging": false,
		"objectPattern.preferSingleLine": false,
		"objectPattern.spaceSurroundingProperties": true,
		"objectPattern.trailingCommas": "never",
		"operatorPosition": "maintain",
		"parameters.preferHanging": "never",
		"parameters.preferSingleLine": false,
		"parameters.spaceAround": false,
		"parameters.trailingCommas": "never",
		"parenExpression.spaceAround": false,
		"parentheses.preferSingleLine": false,
		"preferHanging": false,
		"preferSingleLine": false,
		"quoteProps": "consistent",
		"quoteStyle": "preferSingle",
		"semiColons": "always",
		"sequenceExpression.preferHanging": false,
		"setAccessor.bracePosition": "sameLine",
		"setAccessor.spaceBeforeParentheses": false,
		"singleBodyPosition": "maintain",
		"spaceAround": false,
		"spaceSurroundingProperties": true,
		"staticBlock.bracePosition": "sameLine",
		"switchCase.bracePosition": "sameLine",
		"switchStatement.bracePosition": "sameLine",
		"switchStatement.preferHanging": false,
		"switchStatement.spaceAround": false,
		"taggedTemplate.spaceBeforeLiteral": false,
		"trailingCommas": "never",
		"tryStatement.bracePosition": "sameLine",
		"tryStatement.nextControlFlowPosition": "sameLine",
		"tupleType.preferHanging": "never",
		"tupleType.preferSingleLine": false,
		"tupleType.spaceAround": false,
		"tupleType.trailingCommas": "never",
		"typeAnnotation.spaceBeforeColon": false,
		"typeAssertion.spaceBeforeExpression": true,
		"typeLiteral.preferHanging": false,
		"typeLiteral.preferSingleLine": false,
		"typeLiteral.separatorKind.multiLine": "comma",
		"typeLiteral.separatorKind.singleLine": "comma",
		"typeLiteral.separatorKind": "comma",
		"typeLiteral.spaceSurroundingProperties": true,
		"typeLiteral.trailingCommas": "never",
		"typeParameters.preferHanging": "never",
		"typeParameters.preferSingleLine": false,
		"typeParameters.trailingCommas": "never",
		"unionAndIntersectionType.preferHanging": false,
		"unionAndIntersectionType.preferSingleLine": false,
		"useBraces": "always",
		"variableStatement.preferHanging": false,
		"variableStatement.preferSingleLine": false,
		"whileStatement.bracePosition": "sameLine",
		"whileStatement.preferHanging": false,
		"whileStatement.singleBodyPosition": "maintain",
		"whileStatement.spaceAfterWhileKeyword": true,
		"whileStatement.spaceAround": false,
		"whileStatement.useBraces": "always"
	},
	"yaml": {
		"indentWidth": 2,
		"printWidth": 180,
		"lineBreak": "lf",

		"braceSpacing": true,
		"bracketSpacing": false,
		"dashSpacing": "oneSpace",
		"formatComments": false,
		"ignoreCommentDirective": "dprint-ignore",
		"indentBlockSequenceInMap": true,
		"preferSingleLine": false,
		"proseWrap": "preserve",
		"quotes": "preferDouble",
		"trailingComma": true,
		"trimTrailingWhitespaces": true,
		"trimTrailingZero": false
	},
	"plugins": [
		"https://plugins.dprint.dev/dockerfile-0.4.1.wasm",
		"https://plugins.dprint.dev/g-plane/malva-v0.16.0.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
		"https://plugins.dprint.dev/json-0.22.0.wasm",
		"https://plugins.dprint.dev/markdown-0.22.1.wasm",
		"https://plugins.dprint.dev/toml-0.7.0.wasm",
		"https://plugins.dprint.dev/typescript-0.96.1.wasm"
	]
}
